    {
      "name": "05 - REST RLS / SQLi / XSS Probes",
      "item": [
        {
          "name": "profiles sem JWT nao deve vazar dados",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('sem JWT nao retorna lista ampla de perfis', () => { pm.expect([200, 401, 403]).to.include(pm.response.code); if (pm.response.code === 200) pm.expect(pm.response.json()).to.be.an('array').with.lengthOf(0); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Prefer", "value": "count=exact" }],
            "url": {
              "raw": "{{supabase_url}}/rest/v1/profiles?select=id,name,role,email&limit=50",
              "host": ["{{supabase_url}}"],
              "path": ["rest", "v1", "profiles"],
              "query": [
                { "key": "select", "value": "id,name,role,email" },
                { "key": "limit", "value": "50" }
              ]
            }
          }
        },
        {
          "name": "SQLi probe em profiles nao deve causar 500 nem vazar tudo",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('sem 500', () => pm.expect(pm.response.code).to.not.equal(500));",
                  "pm.test('nao retorna dump amplo', () => { if (pm.response.code === 200) pm.expect(pm.response.json().length).to.be.below(5); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{supabase_url}}/rest/v1/profiles?select=id,name&name=ilike.*%27%20or%20%271%27%3D%271*",
              "host": ["{{supabase_url}}"],
              "path": ["rest", "v1", "profiles"],
              "query": [
                { "key": "select", "value": "id,name" },
                { "key": "name", "value": "ilike.*%27%20or%20%271%27%3D%271*" }
              ]
            }
          }
        },
        {
          "name": "XSS probe em chat_messages como texto deve permanecer texto",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('insert bloqueado ou criado com texto literal', () => pm.expect([201, 400, 401, 403]).to.include(pm.response.code));",
                  "if (pm.response.code === 201) { const j = pm.response.json()[0]; pm.collectionVariables.set('xss_message_id', j.id); pm.test('conteudo continua literal', () => pm.expect(j.content).to.include('<img')); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Prefer", "value": "return=representation" }
            ],
            "body": {
              "mode": "raw",
              "raw": "[{\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"sender_id\": \"{{user_id}}\",\n  \"receiver_id\": \"{{other_user_id}}\",\n  \"content\": \"<img src=x onerror=alert(1)><script>alert(1)</script>\",\n  \"type\": \"text\"\n}]"
            },
            "url": {
              "raw": "{{supabase_url}}/rest/v1/chat_messages",
              "host": ["{{supabase_url}}"],
              "path": ["rest", "v1", "chat_messages"]
            }
          }
        }
      ]
