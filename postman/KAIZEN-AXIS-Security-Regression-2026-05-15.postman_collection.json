  "item": [
    {
      "name": "00 - Setup / Auth",
      "item": [
        {
          "name": "Login - obter JWT e user_id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login retornou 200', () => pm.response.to.have.status(200));",
                  "pm.test('resposta contem access_token', () => pm.expect(pm.response.json()).to.have.property('access_token'));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access_token);",
                  "pm.collectionVariables.set('user_id', json.user && json.user.id ? json.user.id : '');",
                  "pm.test('user_id foi capturado', () => pm.expect(pm.collectionVariables.get('user_id')).to.not.equal(''));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{supabase_url}}/auth/v1/token?grant_type=password",
              "host": ["{{supabase_url}}"],
              "path": ["auth", "v1", "token"],
              "query": [{ "key": "grant_type", "value": "password" }]
            },
            "description": "Autentica o usuario de teste e salva access_token/user_id para os demais requests."
          }
        },
        {
          "name": "Auth user - token valido",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('usuario autenticado', () => pm.response.to.have.status(200));",
                  "pm.test('id bate com variavel user_id', () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('user_id')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{supabase_url}}/auth/v1/user",
              "host": ["{{supabase_url}}"],
              "path": ["auth", "v1", "user"]
            }
          }
        }
      ]
    },
