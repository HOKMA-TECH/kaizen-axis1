{
  "info": {
    "_postman_id": "c84c4928-c3c6-4c4d-86e1-4b2cb7a5f8b0",
    "name": "Kaizen - Send Push Security Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Testes de seguranca, contrato e validacao da Edge Function send-push"
  },
  "item": [
    {
      "name": "01 - send-push sem Authorization (deve 401)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "apikey", "value": "{{anon_key}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"notification\": {\n    \"target_user_id\": \"{{target_user_id}}\",\n    \"title\": \"Teste sem auth\",\n    \"message\": \"Sem token\"\n  }\n}"
        },
        "url": {
          "raw": "{{functions_base_url}}/send-push",
          "host": ["{{functions_base_url}}"],
          "path": ["send-push"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status deve ser 401', function () {",
              "  pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - send-push com token sem role permitida (deve 403)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "apikey", "value": "{{anon_key}}" },
          { "key": "Authorization", "value": "Bearer {{token_forbidden}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"notification\": {\n    \"target_user_id\": \"{{target_user_id}}\",\n    \"title\": \"Teste role negada\",\n    \"message\": \"Token sem permissao\"\n  }\n}"
        },
        "url": {
          "raw": "{{functions_base_url}}/send-push",
          "host": ["{{functions_base_url}}"],
          "path": ["send-push"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status deve ser 403', function () {",
              "  pm.response.to.have.status(403);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - send-push com token permitido (deve 200)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "apikey", "value": "{{anon_key}}" },
          { "key": "Authorization", "value": "Bearer {{token_allowed}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"notification\": {\n    \"target_user_id\": \"{{target_user_id}}\",\n    \"title\": \"Teste autorizado\",\n    \"message\": \"Push com role permitida\",\n    \"reference_route\": \"/\"\n  }\n}"
        },
        "url": {
          "raw": "{{functions_base_url}}/send-push",
          "host": ["{{functions_base_url}}"],
          "path": ["send-push"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status deve ser 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - send-push sem target_user_id (deve 422)",
      "request": {
