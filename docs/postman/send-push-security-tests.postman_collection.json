              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "06 - send-push payload com campo inesperado (deve 422)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "apikey", "value": "{{anon_key}}" },
