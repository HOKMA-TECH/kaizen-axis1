        "body": {
          "mode": "raw",
          "raw": "{\n  \"notification\": {\n    \"target_user_id\": \"{{target_user_id}}\",\n    \"title\": \"Payload extra\",\n    \"message\": \"Teste\",\n    \"unexpected\": \"nao permitido\"\n  }\n}"
        },
        "url": {
          "raw": "{{functions_base_url}}/send-push",
