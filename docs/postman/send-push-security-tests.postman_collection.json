        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"notification\": {\n    \"title\": \"Sem target\",\n    \"message\": \"Payload invalido\"\n  }\n}"
        },
        "url": {
          "raw": "{{functions_base_url}}/send-push",
