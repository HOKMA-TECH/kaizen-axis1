# Push Notifications (Web Push / VAPID)
# Gerar par de chaves: node -e "require('crypto').generateKeyPairSync(...)"
# A chave pública vai aqui; a privada vai nos Supabase Secrets como VAPID_PRIVATE_KEY
VITE_VAPID_PUBLIC_KEY="SUA_VAPID_PUBLIC_KEY_AQUI"

# Cloudflare Turnstile (Captcha para login/signup/reset)
# Preencha com a Site Key (publica) do widget Turnstile
VITE_TURNSTILE_SITE_KEY="SUA_TURNSTILE_SITE_KEY_AQUI"

