{
    "name": "kaizen-apuracao-server",
    "version": "1.0.0",
    "description": "Motor determinístico de apuração de renda — Kaizen Axis",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "jest --forceExit"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.18.3",
        "multer": "^1.4.5-lts.1",
        "pdf-parse": "^1.1.1"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.12",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.12.7",
        "@types/pdf-parse": "^1.1.4",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.5"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "roots": [
            "<rootDir>/tests"
        ],
        "testMatch": [
            "**/*.test.ts"
        ]
    }
}